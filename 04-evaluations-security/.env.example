# Project endpoint of the Foundry project provisioned by the cloud-infra team
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>

# Chat-completions deployment used by the agent under evaluation
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Azure OpenAI endpoint + deployment that powers the AI-assisted evaluators
# (groundedness, relevance, coherence, content safety, ...). Often the same
# Foundry resource, but a separate variable so you can swap judges later.
# Azure OpenAI endpoint + a non-gpt-5 judge model used by the AI-assisted
# evaluators (groundedness, relevance, coherence). gpt-5 isn't compatible
# with azure-ai-evaluation's bundled prompts (max_tokens vs
# max_completion_tokens), so we deploy a small gpt-4o-mini just for judging.
AZURE_OPENAI_ENDPOINT=https://<your-foundry-resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-judge
AZURE_OPENAI_API_VERSION=2024-10-21
