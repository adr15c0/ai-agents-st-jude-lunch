# Foundry project + model — same values the cloud-infra team gave you
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Set by the Container App at deploy time; left blank locally so DefaultAzureCredential
# falls back to your `az login` identity.
AZURE_CLIENT_ID=
